# devops/ holds every per-deployment file: rendered Compose files (devops/docker/) and real
# Traefik dynamic config (devops/traefik/bench-00.yml, etc.). All of it is local to the checkout,
# same pattern as .env below. Only .gitkeep is tracked, to keep the empty directory structure.
devops/**
!devops/**/
!devops/**/.gitkeep

.env
