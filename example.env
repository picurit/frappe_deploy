# Copy to .env and adjust:  cp example.env .env

# --- Runtime UID/GID remap of the `frappe` user (templates/docker/compose.uid-gid.yml) ---
# Match your host user so bind-mounted files stay writable. Defaults to 1000/1000 if unset.
USERID=1000
GROUPID=1000

# --- Bench dev ports (used by local-ports override) ---
# Ports the bench dev server binds INSIDE the container. Defaults are bench's own defaults.
# bench init -> make_ports() gives a second bench 8001/9001, a third 8002/9002, ... Point a
# stack at a non-default bench by bumping these (e.g. FRAPPE_WEB_PORT=8001 / FRAPPE_SOCKETIO_PORT=9001).
FRAPPE_WEB_PORT=8000
FRAPPE_SOCKETIO_PORT=9000
# High bound of the range published locally (local-ports override only). Lets bench's dynamic
# +1 allocation stay reachable on the host without editing the override.
FRAPPE_WEB_PORT_LAST=8005
FRAPPE_SOCKETIO_PORT_LAST=9005

# --- Local ports override (templates/docker/compose.local-ports.yml) ---
# Host interface the bench ports bind to. Loopback-only by default; set 0.0.0.0 to reach it from the LAN.
HOST_BIND=127.0.0.1

# --- HTTPS / Traefik override (templates/docker/compose.non-prod-https.yaml) ---
# Host ports Traefik publishes.
HTTP_PUBLISH_PORT=80
HTTPS_PUBLISH_PORT=443

# Email for Let's Encrypt notifications (no leading space — passed verbatim to ACME).
# Required for the Traefik/HTTPS override.
LETSENCRYPT_EMAIL=admin@example.com

# ACME directory. Default = Let's Encrypt production. Use staging while testing to avoid rate limits:
# ACME_CA_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory
ACME_CA_SERVER=https://acme-v02.api.letsencrypt.org/directory
