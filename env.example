# Copy to .env and adjust:  cp env.example .env

# --- Runtime UID/GID remap of the `frappe` user (overrides/compose.uid-gid.yml) ---
# Match your host user so bind-mounted files stay writable. Defaults to 1000/1000 if unset.
USERID=1000
GROUPID=1000

# --- Local ports override (overrides/compose.local-ports.yml) ---
# Host interface the bench ports bind to. Loopback-only by default; set 0.0.0.0 to reach it from the LAN.
HOST_BIND=127.0.0.1

# --- HTTPS / Traefik override (overrides/compose.non-prod-https.yaml) ---
# Host ports Traefik publishes.
HTTP_PUBLISH_PORT=80
HTTPS_PUBLISH_PORT=443

# Email for Let's Encrypt notifications (no leading space — passed verbatim to ACME).
LETSENCRYPT_EMAIL=admin@example.com

# ACME directory. Default = Let's Encrypt production. Use staging while testing to avoid rate limits:
# ACME_CA_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory
ACME_CA_SERVER=https://acme-v02.api.letsencrypt.org/directory

# Router rule for the site(s).
# Single site:    SITES_RULE=Host(`erp.example.com`)
# Multiple sites: SITES_RULE=Host(`a.example.com`) || Host(`b.example.com`)
SITES_RULE=Host(`erp.example.com`)
